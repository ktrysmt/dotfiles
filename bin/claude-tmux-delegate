#!/bin/bash

tmpfile=$(mktemp /tmp/claude-delegate-XXXXXX)
trap 'rm -f "$tmpfile"' EXIT

${EDITOR:-vim} -c 'setfiletype markdown' "$tmpfile"

task=$(cat "$tmpfile")
[ -z "$task" ] && exit 0

tmux set-environment -g __CLAUDE_DELEGATE_TASK "$task"
tmux split-window -d -h -p 33 -c "$PWD" \
  'claude --continue --fork-session "$__CLAUDE_DELEGATE_TASK"; tmux set-environment -gu __CLAUDE_DELEGATE_TASK'
