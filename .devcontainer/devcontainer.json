{
  "name": "Claude Code Sandbox",
  "image": "ghcr.io/ktrysmt/claude-devcontainer:latest",
  "initializeCommand": "mkdir -p ${HOME}/.claude-devcontainer ${TMUX_TMPDIR:-/tmp/tmux-1000}",
  "runArgs": [
    "--cap-add=SYS_ADMIN",
    "--cap-add=NET_RAW",
    "--ulimit", "memlock=-1:-1"
  ],
  "remoteUser": "ubuntu",
  "mounts": [
    "source=${localEnv:HOME}/.claude-devcontainer,target=/home/ubuntu/.claude,type=bind",
    "source=claude-bashhistory-${devcontainerId},target=/commandhistory,type=volume",
    "source=${localEnv:TMUX_TMPDIR:/tmp/tmux-1000},target=${localEnv:TMUX_TMPDIR:/tmp/tmux-1000},type=bind",
    "source=claude-uv-python-${devcontainerId},target=/home/ubuntu/.local/share/uv/python,type=volume",
    "source=claude-uv-cache-${devcontainerId},target=/home/ubuntu/.cache/uv,type=volume"
  ],
  "containerEnv": {
    "NODE_OPTIONS": "--max-old-space-size=4096",
    "DEVCONTAINER": "true",
    "DEVCONTAINER_HOST_PATH": "${localWorkspaceFolder}",
    "TERM": "xterm-256color",
    "COLORTERM": "truecolor"
  },
  "workspaceMount": "source=${localWorkspaceFolder},target=/workspace,type=bind,consistency=delegated",
  "workspaceFolder": "/workspace",
  "postStartCommand": {
    "network-trace": "sudo /usr/local/bin/trace-network.sh || true",
    "claude-setup": "bash /usr/local/bin/setup-claude.sh",
    "mcp-sync": "for d in /workspace/_*/; do [ -f \"$d/pyproject.toml\" ] && (cd \"$d\" && uv sync --quiet 2>/dev/null); done; true"
  },
  "waitFor": "postStartCommand"
}
