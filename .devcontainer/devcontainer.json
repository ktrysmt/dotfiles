{
  "name": "Claude Code Sandbox",
  "image": "ghcr.io/ktrysmt/claude-devcontainer:latest",
  "initializeCommand": {
    "setup-dirs": "mkdir -p ${HOME}/.claude-devcontainer ${TMUX_SOCK_DIR:-/tmp/tmux-1000} /tmp/claude",
    "tmux-relay": "[ \"$(uname)\" = \"Darwin\" ] && SOCK=${TMUX%%,*} && command -v socat >/dev/null 2>&1 && [ -S \"$SOCK\" ] && { pkill -f 'socat.*TCP-LISTEN:2489' 2>/dev/null; socat TCP-LISTEN:2489,bind=127.0.0.1,reuseaddr,fork SYSTEM:'read action pane; TMUX_PANE=$pane bash ~/.claude/hooks/tmux-window-claude-status.sh $action' >/dev/null 2>&1 & } || true"
  },
  "runArgs": [
    "--cap-add=SYS_ADMIN",
    "--ulimit", "memlock=-1:-1"
  ],
  "remoteUser": "ubuntu",
  "mounts": [
    "source=${localEnv:HOME}/.claude-devcontainer,target=/home/ubuntu/.claude,type=bind",
    "source=${localEnv:TMUX_SOCK_DIR:/tmp/tmux-1000},target=${localEnv:TMUX_SOCK_DIR:/tmp/tmux-1000},type=bind",
    "source=/tmp/claude,target=/tmp/claude,type=bind"
  ],
  "containerEnv": {
    "NODE_OPTIONS": "--max-old-space-size=4096",
    "DEVCONTAINER": "true",
    "XDG_CACHE_HOME": "/tmp/claude/cache",
    "UV_PYTHON_INSTALL_DIR": "/tmp/claude/uv-python",
    "DEVCONTAINER_HOST_PATH": "${localWorkspaceFolder}",
    "TERM": "xterm-256color",
    "COLORTERM": "truecolor"
  },
  "remoteEnv": {
    "TMUX": "${localEnv:TMUX}",
    "TMUX_PANE": "${localEnv:TMUX_PANE}"
  },
  "workspaceMount": "source=${localWorkspaceFolder},target=/workspace,type=bind",
  "workspaceFolder": "/workspace",
  "postStartCommand": {
    "network-trace": "sudo /usr/local/bin/trace-network.sh || true",
    "claude-setup": "bash /usr/local/bin/setup-claude.sh",
    "mcp-sync": "for d in /workspace/_*/; do [ -f \"$d/pyproject.toml\" ] && (cd \"$d\" && uv sync --quiet 2>/dev/null); done; true"
  },
  "waitFor": "postStartCommand"
}
