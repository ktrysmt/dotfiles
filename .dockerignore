# Only send what the Dockerfile needs
*

!.devcontainer/trace-network.sh
!.devcontainer/setup-claude.sh
!.devcontainer/mise.toml
!claude/
!claude/**
!.gitignore_global

# Exclude unnecessary claude files
claude/hooks/__pycache__/
claude/hooks/.ruff_cache/
claude/hooks/*.log
claude/settings.local.json
claude/README.md
